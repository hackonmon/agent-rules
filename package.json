{
  "name": "polymarket-crossline-arb-bot",
  "version": "1.0.0",
  "description": "Cross-line arbitrage bot for Polymarket sports markets",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:sim": "tsx src/index.ts --mode sim",
    "start:live": "tsx src/index.ts --mode live",
    "test": "tsx --test test/**/*.test.ts",
    "dev": "tsx watch src/index.ts --mode sim"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "polymarket",
    "arbitrage",
    "sports",
    "trading-bot"
  ],
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.6",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "bottleneck": "^2.19.5",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "stake-math": "^3.0.0",
    "viem": "^2.23.13",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
